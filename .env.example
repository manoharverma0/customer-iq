# ─── HuggingFace ──────────────────────────────────────────────────────────────
# Get a free token from: https://huggingface.co/settings/tokens
# Required permission: "Make calls to Inference Providers"
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Twilio WhatsApp ──────────────────────────────────────────────────────────
# Get credentials from: https://console.twilio.com
# Setup: Messaging → Try it out → WhatsApp Sandbox
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# The full public URL of your deployed webhook (update after deploying)
# For local dev: use ngrok → ngrok http 3000
TWILIO_WEBHOOK_URL=https://your-domain.vercel.app/api/webhook/whatsapp
